# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Node environment (development, staging, production)
NODE_ENV=production

# Port for the backend server
# In cPanel: usually assigned by Node.js Selector
# In local development: 5000 is a safe default
PORT=5000

# ===========================================
# DATABASE CONFIGURATION (MySQL)
# ===========================================
# In cPanel, usually: localhost
DB_HOST=localhost
# cPanel database username format: cpanelusername_dbuser
DB_USER=cpanelusername_dbuser
# Your database user password
DB_PASSWORD=your_secure_database_password
# cPanel database name format: cpanelusername_dbname
DB_NAME=cpanelusername_dbname
DB_PORT=3306

# ===========================================
# SECURITY
# ===========================================
# Generate a strong random string (32+ characters)
# Use: openssl rand -base64 32
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_32_characters

# Cookie SameSite policy for admin auth cookies.
# Use Lax for same-site deployments, None for cross-site frontend/backend setups.
# Valid values: Lax, Strict, None
COOKIE_SAME_SITE=Lax

# Admin bootstrap credentials used by createAdminUser.js
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_secure_password

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Your frontend domain for CORS and CSP. No trailing slash.
# In production this must match the deployed frontend origin.
FRONTEND_URL=https://your-domain.com
# Optional: comma-separated list of additional allowed frontend origins.
# Useful when supporting both www/non-www or staging frontend origins.
# Example: FRONTEND_URLS=https://www.your-domain.com,https://staging.your-domain.com
FRONTEND_URLS=

# ===========================================
# LOGGING & SESSION CONFIGURATION
# ===========================================
# Log level: error, warn, info, debug
LOG_LEVEL=error
# Session timeout in milliseconds (900000 = 15 minutes)
SESSION_TIMEOUT=900000

# Allowed upload file types for validation
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,webm,pdf
